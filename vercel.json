{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://clarustologistics.com/$1",
      "permanent": true,
      "has": [
        { "type": "host", "value": "new-cl-sigma.vercel.app" }
      ]
    }
  ]
}
